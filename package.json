{
  "name": "codestream-ci-cd-demo",
  "version": "1.0.0",
  "description": "Demo CI/CD pipeline for CodeStream internal project",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "lint": "eslint .",
    "test": "jest --runInBand",
    "test:ci": "jest --runInBand --ci --reporters=default --reporters=jest-junit",
    "test:coverage": "jest --runInBand --ci --coverage --reporters=default --reporters=jest-junit",
    "build": "node scripts/build.js",
    "deploy:mock": "node scripts/deploy.js",
    "deploy:rollback": "node scripts/rollback.js",
    "ci": "npm run lint && npm run test && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ci",
    "cd",
    "github-actions",
    "pipeline",
    "demo"
  ],
  "author": "CodeStream Student Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "supertest": "^7.0.0"
  }
}